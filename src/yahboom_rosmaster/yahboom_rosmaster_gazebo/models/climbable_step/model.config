<?xml version="1.0" ?>
<model>
    <name>climbable_step</name>
    <version>1.0</version>
    <sdf version="1.6">model.sdf</sdf>

    <author>
      <name>asana17</name>
      <email>kei17.kaight084@gmail.com</email>
    </author>

    <description>
      A low step sized so the ROSMASTER X3 mecanum wheel (radius 0.0325 m) can
      drive over it without getting stuck. The main step is 10 mm high
      (~31 % of the wheel radius) with a 5 mm lead-in lip. Surfaces have
      friction so the friction-driven wheels can grip and climb.
    </description>
</model>
